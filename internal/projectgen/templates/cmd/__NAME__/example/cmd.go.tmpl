// Package example contains a placeholder subcommand for new projects.
package example

import (
	"{{ .ModulePath }}/cmd"
	"{{ .ModulePath }}/internal/appconfig"
	"github.com/rs/zerolog"
)

// Command is a placeholder subcommand implementation.
type Command struct{}

// Run demonstrates how shared globals and app config are injected into handlers.
func (c *Command) Run(log zerolog.Logger, g *cmd.Globals, cfg *appconfig.Config) error {
	log.Info().
		Str("config_file", g.ConfigFile).
		Str("root_path", cfg.RootPath).
		Str("git_location", cfg.GitLocation).
		Msg("example command")
	return nil
}
