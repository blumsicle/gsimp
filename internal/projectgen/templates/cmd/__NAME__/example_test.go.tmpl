package main

import (
	"bytes"
	"os"
	"path/filepath"
	"testing"

	"{{ .ModulePath }}/internal/appconfig"
	cliutil "{{ .ModulePath }}/internal/cli"
	"github.com/rs/zerolog"
	"github.com/stretchr/testify/assert"
	"github.com/stretchr/testify/require"
)

func TestConfigFileLoadsAndFlagOverridesIt(t *testing.T) {
	configPath := filepath.Join(t.TempDir(), "config.yaml")
	require.NoError(
		t,
		os.WriteFile(
			configPath,
			[]byte(
				"root_path: /from-config\ngit_location: github.com/from-config\nlog_level: debug\n",
			),
			0o644,
		),
	)

	appConfig := &appconfig.Config{}
	harness := newCLITestHarness(t, appConfig)

	flagLogLevel := zerolog.WarnLevel
	ctx, err := harness.parse(
		t,
		"--config-file", configPath,
		"--log-level", "warn",
		"example",
	)
	require.NoError(t, err)

	assert.Equal(t, "/from-config", appConfig.RootPath)
	assert.Equal(t, "github.com/from-config", appConfig.GitLocation)
	assert.Equal(t, flagLogLevel, appConfig.LogLevel)

	var logs bytes.Buffer
	log := zerolog.New(&logs)

	err = cliutil.Run(ctx, log)
	require.NoError(t, err)

	assert.Equal(t, -1, harness.exitCode)
	assert.Contains(t, logs.String(), "example command")
	assert.Contains(t, logs.String(), configPath)
	assert.Contains(t, logs.String(), "/from-config")
}

func TestExampleCommandFlagOverridesConfig(t *testing.T) {
	configPath := filepath.Join(t.TempDir(), "config.yaml")
	require.NoError(
		t,
		os.WriteFile(
			configPath,
			[]byte("root_path: /from-config\ngit_location: github.com/from-config\n"),
			0o644,
		),
	)

	appConfig := appconfig.Default()
	harness := newCLITestHarness(t, appConfig)

	flagRootPath := "/from-flag"
	flagGitLocation := "github.com/from-flag"
	ctx, err := harness.parse(
		t,
		"--config-file", configPath,
		"example",
		"--root-path", flagRootPath,
		"--git-location", flagGitLocation,
	)
	require.NoError(t, err)

	assert.Equal(t, flagRootPath, appConfig.RootPath)
	assert.Equal(t, flagGitLocation, appConfig.GitLocation)

	var logs bytes.Buffer
	log := zerolog.New(&logs)

	err = cliutil.Run(ctx, log)
	require.NoError(t, err)

	assert.Contains(t, logs.String(), flagRootPath)
	assert.Contains(t, logs.String(), flagGitLocation)
	assert.Equal(t, -1, harness.exitCode)
	assert.Empty(t, harness.stdoutString())
	assert.Empty(t, harness.stderrString())
}
