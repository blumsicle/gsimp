// Package main defines the root command-line interface for {{ .Name }}.
package main

import (
	"{{ .ModulePath }}/cmd"
	"{{ .ModulePath }}/cmd/{{ .Name }}/completion"
	"{{ .ModulePath }}/cmd/{{ .Name }}/config"
	"{{ .ModulePath }}/cmd/{{ .Name }}/example"
	"{{ .ModulePath }}/internal/appconfig"
)

// CLI defines the root command tree for the {{ .Name }} binary.
type CLI struct {
	cmd.Globals

	Completion completion.Command `cmd:"" help:"Generate shell completions"`
	Config     config.Command     `cmd:"" help:"Write the resolved config as YAML"`
	Example    example.Command    `cmd:"" help:"Example subcommand for new projects"`
}

// AfterApply loads file-backed config and applies root flag overrides.
func (c *CLI) AfterApply(cfg *appconfig.Config) error {
	if err := cfg.LoadYAML(c.ConfigFile); err != nil {
		return err
	}

	cfg.ApplyRootOverrides(appconfig.RootOverrides{
		LogLevel: c.LogLevel,
	})

	return nil
}
