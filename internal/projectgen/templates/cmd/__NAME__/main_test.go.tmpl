package main

import (
	"bytes"
	"os"
	"path/filepath"
	"testing"

	"github.com/alecthomas/kong"
	"{{ .ModulePath }}/internal/appconfig"
	cliutil "{{ .ModulePath }}/internal/cli"
	"github.com/rs/zerolog"
	"github.com/stretchr/testify/assert"
	"github.com/stretchr/testify/require"
)

func testConfig() cliutil.Config {
	return cliutil.Config{
		Description: "{{ .Description }}",
		BuildInfo: cliutil.BuildInfo{
			Name:    "{{ .Name }}",
			Version: "test-version",
			Commit:  "test-commit",
		},
	}
}

func newTestParser(
	t *testing.T,
	cli *CLI,
	appConfig *appconfig.Config,
	stdout *bytes.Buffer,
	stderr *bytes.Buffer,
	exitCode *int,
) *kong.Kong {
	t.Helper()

	parser, err := cliutil.New(
		cli,
		testConfig(),
		kong.Bind(&cli.Globals),
		kong.Bind(appConfig),
		kong.Writers(stdout, stderr),
		kong.Exit(func(code int) {
			*exitCode = code
		}),
	)
	require.NoError(t, err)

	return parser
}

func TestVersionFlag(t *testing.T) {
	cli := &CLI{}
	appConfig := &appconfig.Config{}
	var stdout bytes.Buffer
	var stderr bytes.Buffer
	exitCode := -1

	parser := newTestParser(t, cli, appConfig, &stdout, &stderr, &exitCode)

	_, err := parser.Parse([]string{"--version"})
	require.Error(t, err)

	assert.Equal(t, 0, exitCode)
	assert.Equal(t, "{{ .Name }} test-version test-commit\n", stdout.String())
	assert.Empty(t, stderr.String())
}

func TestHelpFlag(t *testing.T) {
	cli := &CLI{}
	appConfig := &appconfig.Config{}
	var stdout bytes.Buffer
	var stderr bytes.Buffer
	exitCode := -1

	parser := newTestParser(t, cli, appConfig, &stdout, &stderr, &exitCode)

	_, err := parser.Parse([]string{"--help"})
	require.Error(t, err)

	assert.Equal(t, 0, exitCode)
	assert.Contains(t, stdout.String(), "{{ .Description }}")
	assert.Contains(t, stdout.String(), "--config-file")
	assert.Contains(t, stdout.String(), "--log-level")
	assert.Contains(t, stdout.String(), "example")
	assert.Empty(t, stderr.String())
}

func TestConfigFileLoadsAndFlagOverridesIt(t *testing.T) {
	configPath := filepath.Join(t.TempDir(), "config.yaml")
	require.NoError(
		t,
		os.WriteFile(
			configPath,
			[]byte(
				"root_path: /from-config\ngit_location: github.com/from-config\nlog_level: debug\n",
			),
			0o644,
		),
	)

	cli := &CLI{}
	appConfig := &appconfig.Config{}
	var stdout bytes.Buffer
	var stderr bytes.Buffer
	exitCode := -1

	parser := newTestParser(t, cli, appConfig, &stdout, &stderr, &exitCode)

	flagLogLevel := zerolog.WarnLevel
	ctx, err := parser.Parse([]string{
		"--config-file", configPath,
		"--log-level", "warn",
		"example",
	})
	require.NoError(t, err)

	assert.Equal(t, "/from-config", appConfig.RootPath)
	assert.Equal(t, "github.com/from-config", appConfig.GitLocation)
	assert.Equal(t, flagLogLevel, appConfig.LogLevel)

	var logs bytes.Buffer
	log := zerolog.New(&logs)

	err = cliutil.Run(ctx, log)
	require.NoError(t, err)

	assert.Equal(t, -1, exitCode)
	assert.Contains(t, logs.String(), "example command")
	assert.Contains(t, logs.String(), configPath)
	assert.Contains(t, logs.String(), "/from-config")
}
