package appconfig

import (
	"os"
	"os/user"
	"path/filepath"
	"testing"

	"github.com/stretchr/testify/assert"
	"github.com/stretchr/testify/require"
)

func TestNormalizeExpandsRootPath(t *testing.T) {
	homeDir, err := os.UserHomeDir()
	require.NoError(t, err)
	currentUser, err := user.Current()
	require.NoError(t, err)

	t.Setenv("{{ upper .Name }}_TEST_HOME", "/tmp/home")
	t.Setenv("{{ upper .Name }}_RELATIVE_ROOT", "~/from-env")
	t.Setenv("{{ upper .Name }}_GIT_HOST", "github.com")

	tests := []struct {
		name string
		root string
		want string
	}{
		{
			name: "environment variable",
			root: "${{ upper .Name }}_TEST_HOME/src",
			want: "/tmp/home/src",
		},
		{
			name: "tilde",
			root: "~/src",
			want: filepath.Join(homeDir, "src"),
		},
		{
			name: "bare tilde",
			root: "~",
			want: homeDir,
		},
		{
			name: "environment variable to tilde",
			root: "${{ upper .Name }}_RELATIVE_ROOT/project",
			want: filepath.Join(homeDir, "from-env", "project"),
		},
		{
			name: "non-leading tilde",
			root: "/tmp/~/src",
			want: "/tmp/~/src",
		},
		{
			name: "named user tilde",
			root: "~" + currentUser.Username + "/src",
			want: filepath.Join(homeDir, "src"),
		},
		{
			name: "unknown named user tilde",
			root: "~{{ .Name }}-user-that-should-not-exist/src",
			want: "~{{ .Name }}-user-that-should-not-exist/src",
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			cfg := &Config{
				RootPath:    tt.root,
				GitLocation: "${{ upper .Name }}_GIT_HOST/acme",
			}

			cfg.Normalize()

			assert.Equal(t, tt.want, cfg.RootPath)
			assert.Equal(t, "${{ upper .Name }}_GIT_HOST/acme", cfg.GitLocation)
		})
	}
}
